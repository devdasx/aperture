        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tôi hiểu rằng nếu mất cụm từ khôi phục, tôi sẽ mất tiền điện tử của mình."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ฉันเข้าใจว่าหากสูญเสียวลีกู้คืน ฉันจะสูญเสียคริปโตของฉัน"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Saya memahami bahwa jika kehilangan frasa pemulihan, saya kehilangan kripto saya."
