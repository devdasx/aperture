        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Capisco che se perdo la mia frase di ripristino, perdo le mie cripto."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurtarma ifademi kaybedersem kriptolarımı kaybederim, anlıyorum."
