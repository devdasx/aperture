    "A 24-word phrase is the only key.": {
      "extractionState": "manual",
      "comment": "Slide 5 hero title.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A 24-word phrase is the only key."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una frase de 24 palabras es la única llave."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "24 个单词的短语是唯一的钥匙。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "24 個單字的短語是唯一的鑰匙。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "24 शब्दों का वाक्यांश ही एकमात्र कुंजी है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عبارة من 24 كلمة هي المفتاح الوحيد."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma frase de 24 palavras é a única chave."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "২৪ শব্দের একটি বাক্যাংশই একমাত্র চাবি।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Фраза из 24 слов — единственный ключ."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "24 語のフレーズが、唯一の鍵です。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine 24-Wort-Phrase ist der einzige Schlüssel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une phrase de 24 mots est la seule clé."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단어 24개로 이루어진 문구가 유일한 키입니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una frase di 24 parole è l’unica chiave."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tek anahtarınız 24 kelimelik bir ifadedir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cụm 24 từ là chiếc khóa duy nhất."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "วลี 24 คำคือกุญแจเพียงดอกเดียว"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Frasa 24 kata adalah satu-satunya kunci."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "یک عبارت ۲۴ کلمه‌ای تنها کلید است."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jedynym kluczem jest fraza złożona z 24 słów."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een zin van 24 woorden is de enige sleutel."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Фраза з 24 слів — єдиний ключ."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μια φράση 24 λέξεων είναι το μοναδικό κλειδί."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "O expresie de 24 de cuvinte este singura cheie."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Fráze o 24 slovech je jediný klíč."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Egy 24 szavas kifejezés az egyetlen kulcs."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En fras med 24 ord är den enda nyckeln."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En frase på 24 ord er den eneste nøkkelen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En sætning på 24 ord er den eneste nøgle."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "24 sanan lause on ainoa avain."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ביטוי בן 24 מילים הוא המפתח היחיד."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Una frase de 24 paraules és l'única clau."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fraza od 24 riječi jedini je ključ."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Fráza s 24 slovami je jediný kľúč."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Fraza s 24 besedami je edini ključ."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Фраза од 24 речи једини је кључ."
          }
        }
      }
    },
    "A wallet built with the care a wallet should be built with.": {
      "extractionState": "manual",
      "comment": "Slide 1 body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A wallet built with the care a wallet should be built with."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una billetera construida con el cuidado con que debería construirse una billetera."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "以钱包应有的用心打造的钱包。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "以錢包應有的用心打造的錢包。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक वॉलेट, उसी सावधानी से बनाया गया जिस सावधानी से वॉलेट बनाया जाना चाहिए।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "محفظة صُنعت بالعناية التي يجب أن تُصنع بها أي محفظة."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma carteira feita com o cuidado com que uma carteira deveria ser feita."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একটি ওয়ালেট, যেমন যত্ন দিয়ে একটি ওয়ালেট তৈরি হওয়া উচিত, ঠিক সেভাবে তৈরি।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кошелёк, сделанный с той тщательностью, с какой и должен делаться кошелёк."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ウォレットがこうあるべきという丁寧さで作られたウォレット。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Wallet, gebaut mit der Sorgfalt, mit der eine Wallet gebaut werden sollte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un portefeuille conçu avec le soin qu’un portefeuille mérite."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지갑에 마땅한 정성을 들여 만든 지갑입니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un portafoglio costruito con la cura che un portafoglio merita."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir cüzdanın hak ettiği özenle hazırlandı."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Một ví được tạo nên với sự chăm chút mà một chiếc ví xứng đáng có."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กระเป๋าที่สร้างขึ้นด้วยความใส่ใจอย่างที่กระเป๋าควรได้รับ"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dompet yang dibangun dengan ketelitian selayaknya sebuah dompet."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "کیف پولی که با همان دقتی ساخته شده که شایسته یک کیف پول است."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Portfel zbudowany z troską, na jaką portfel zasługuje."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een wallet gemaakt met de zorg die een wallet verdient."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Гаманець, зроблений із турботою, гідною гаманця."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ένα πορτοφόλι φτιαγμένο με τη φροντίδα που του αξίζει."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Un portofel construit cu grija pe care o merită un portofel."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Peněženka vytvořená s péčí, jakou si peněženka zaslouží."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Egy tárca, amelyet olyan gonddal építettünk, amilyet egy tárca megérdemel."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En plånbok byggd med den omsorg en plånbok förtjänar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En lommebok bygget med den omtanken en lommebok fortjener."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En tegnebog bygget med den omhu, en tegnebog fortjener."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lompakko, joka on rakennettu sillä huolella, jonka lompakko ansaitsee."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ארנק שנבנה במידת תשומת הלב שארנק ראוי לה."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Una cartera construïda amb la cura que mereix una cartera."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Novčanik izrađen s pažnjom kakvu novčanik zaslužuje."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Peňaženka vytvorená so starostlivosťou, akú si peňaženka zaslúži."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Denarnica, izdelana z natančnostjo, ki si jo denarnica zasluži."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Новчаник израђен са пажњом каква новчанику и приличи."
          }
        }
      }
