          "stringUnit": {
            "state": "translated",
            "value": "Entiendo que si pierdo mi frase de recuperación, pierdo mis criptos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我明白：丢失助记词，就等于丢失我的加密资产。"
