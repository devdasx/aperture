    "Your recovery phrase is saved. You can find your wallet on the main screen.": {
      "extractionState": "manual",
      "comment": "Wallet-ready terminal screen body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your recovery phrase is saved. You can find your wallet on the main screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu frase de recuperación está guardada. Encontrarás tu cartera en la pantalla principal."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的恢复短语已保存。可以在主屏幕上找到你的钱包。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的復原短語已儲存。可以在主畫面找到你的錢包。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका रिकवरी फ़्रेज़ सहेज लिया गया है। आपका वॉलेट मुख्य स्क्रीन पर मिल जाएगा।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم حفظ عبارة الاسترداد. ستجد محفظتك في الشاشة الرئيسية."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua frase de recuperação está salva. Você encontra sua carteira na tela inicial."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার রিকভারি ফ্রেজ সংরক্ষিত হয়েছে। মূল স্ক্রিনে আপনি আপনার ওয়ালেট খুঁজে পাবেন।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Восстановительная фраза сохранена. Кошелёк находится на главном экране."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リカバリーフレーズを保存しました。ウォレットはメイン画面で確認できます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Wiederherstellungsphrase ist gesichert. Ihr Wallet finden Sie auf dem Hauptbildschirm."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre phrase de récupération est enregistrée. Vous trouverez votre portefeuille sur l’écran principal."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복구 문구가 저장되었습니다. 메인 화면에서 지갑을 확인할 수 있어요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La sua frase di ripristino è salvata. Può trovare il suo portafoglio nella schermata principale."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurtarma ifadeniz kaydedildi. Cüzdanınızı ana ekranda bulabilirsiniz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cụm từ khôi phục của bạn đã được lưu. Bạn có thể tìm thấy ví của mình trên màn hình chính."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกวลีกู้คืนของคุณแล้ว คุณสามารถพบกระเป๋าของคุณได้บนหน้าจอหลัก"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Frasa pemulihan Anda telah disimpan. Anda dapat menemukan dompet Anda di layar utama."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "عبارت بازیابی شما ذخیره شد. می‌توانید کیف پول خود را در صفحهٔ اصلی پیدا کنید."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Fraza odzyskiwania została zapisana. Portfel znajdziesz na ekranie głównym."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je herstelzin is opgeslagen. Je vindt je wallet op het hoofdscherm."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вашу фразу відновлення збережено. Гаманець доступний на головному екрані."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η φράση ανάκτησής σας αποθηκεύτηκε. Μπορείτε να βρείτε το πορτοφόλι σας στην κύρια οθόνη."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Expresia ta de recuperare e salvată. Portofelul tău e pe ecranul principal."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše obnovovací fráze je uložena. Peněženku najdete na hlavní obrazovce."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A helyreállítási kifejezést elmentettük. A tárcáját a főképernyőn találja."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din återställningsfras är sparad. Du hittar din plånbok på huvudskärmen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjenopprettingsfrasen er lagret. Du finner lommeboken på hovedskjermen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din gendannelsessætning er gemt. Du finder din tegnebog på startskærmen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Palautuslauseesi on tallennettu. Löydät lompakkosi pääruudulta."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ביטוי השחזור שלך נשמר. אפשר למצוא את הארנק במסך הראשי."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva frase de recuperació s’ha desat. Trobaràs la cartera a la pantalla principal."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša fraza za oporavak je spremljena. Novčanik je dostupan na glavnom zaslonu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša obnovovacia fráza je uložená. Peňaženku nájdete na hlavnej obrazovke."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaša obnovitvena fraza je shranjena. Denarnico najdete na glavnem zaslonu."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваша фраза за опоравак је сачувана. Новчаник можете наћи на главном екрану."
          }
        }
      }
    },
