          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiado. A área de transferência será limpa em 60 segundos."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কপি হয়েছে। ক্লিপবোর্ড ৬০ সেকেন্ডে পরিষ্কার হবে।"
          }
        },
        "ru": {
