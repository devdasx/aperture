    "Write it down. Keep it offline. Lose it and the funds are gone — there is no recovery.": {
      "extractionState": "manual",
      "comment": "Slide 5 body. Honesty: explicitly says funds are unrecoverable on loss.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Write it down. Keep it offline. Lose it and the funds are gone — there is no recovery."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Anótala. Mantenla sin conexión. Si la pierdes, los fondos se pierden: no hay recuperación."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "写下来。保持离线。一旦丢失，资金即逝——没有找回。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "寫下來。保持離線。一旦遺失，資金即逝——沒有找回。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे लिख लें। ऑफ़लाइन रखें। खो दिया, तो धन भी गया — कोई रिकवरी नहीं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "دوِّنها. واحتفظ بها دون اتصال. إذا فقدتها، تذهب الأموال — ولا استرداد."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Anote. Mantenha offline. Perdeu, os fundos vão embora — não existe recuperação."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "লিখে রাখুন। অফলাইনে রাখুন। হারালে টাকাও চলে যায় — কোনো রিকভারি নেই।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запишите её. Храните офлайн. Потеряете — потеряете и средства; восстановления не будет."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "書き留め、オフラインで保管してください。失えば資金も失われ——取り戻す術はありません。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schreiben Sie sie auf. Halten Sie sie offline. Verlieren Sie sie, ist das Guthaben weg — es gibt keine Wiederherstellung."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Notez-la. Conservez-la hors ligne. La perdre, c’est perdre les fonds — il n’y a aucune récupération."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "적어 두세요. 오프라인으로 보관하세요. 잃어버리면 자금도 함께 사라집니다 — 복구 수단은 없습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La scriva. La conservi offline. Se la perde, i fondi sono persi — non c’è alcun recupero."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yazıp saklayın. Çevrimdışı tutun. Kaybederseniz fonlar da gider — geri alma yoktur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hãy ghi lại. Giữ ngoại tuyến. Mất nó là mất tiền — không có cách khôi phục."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "จดไว้ เก็บไว้แบบออฟไลน์ หากสูญหาย เงินก็จะหายไปด้วย ไม่มีวิธีกู้คืน"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tulis. Simpan secara luring. Bila hilang, dana ikut hilang — tidak ada pemulihan."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "آن را یادداشت کنید. به‌صورت آفلاین نگه دارید. اگر گم شود، دارایی‌ها از دست می‌روند — هیچ راه بازیابی وجود ندارد."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisz ją. Trzymaj offline. Jej utrata oznacza utratę środków — nie ma odzyskania."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schrijf hem op. Bewaar hem offline. Verlies hem en het geld is weg — er is geen herstel."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запишіть її. Тримайте її офлайн. Втратите — кошти зникнуть, відновлення немає."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Γράψτε τη. Κρατήστε τη εκτός σύνδεσης. Αν τη χάσετε, τα κεφάλαια χάνονται — δεν υπάρχει ανάκτηση."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Scrie-o. Ține-o offline. Dacă o pierzi, fondurile dispar — nu există recuperare."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapište si ji. Držte ji offline. Když ji ztratíte, prostředky jsou pryč — neexistuje obnova."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Írja le. Tartsa offline. Ha elveszíti, a pénzeszközök elvesznek — nincs helyreállítás."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv ner den. Håll den offline. Förlorar du den är pengarna borta — det finns ingen återställning."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv den ned. Hold den frakoblet. Mister du den, er midlene borte — det finnes ingen gjenoppretting."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv den ned. Hold den offline. Mister du den, er midlerne væk — der er ingen gendannelse."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjoita se ylös. Pidä se verkon ulkopuolella. Jos menetät sen, varat ovat poissa — palautusta ei ole."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "רשום אותו. שמור אותו לא מקוון. אם תאבד אותו, הכספים נעלמים — אין שחזור."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Anota-la. Manté-la fora de línia. Si la perds, els fons s’han perdut — no hi ha recuperació."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapišite je. Držite je izvan mreže. Ako je izgubite, sredstva su nestala — oporavka nema."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapíšte si ju. Držte ju offline. Ak ju stratíte, prostriedky sú preč — žiadna obnova neexistuje."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapišite jo. Naj ostane brez povezave. Če jo izgubite, so sredstva izgubljena — obnove ni."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Запишите је. Држите је ван мреже. Ако је изгубите, средства су нестала — опоравка нема."
          }
        }
      }
    },
    "Write it on paper. Keep the paper offline.": {
