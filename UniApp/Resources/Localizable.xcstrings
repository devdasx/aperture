        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, הבנק שלך — אף אחד לא צריך את ביטוי השחזור שלך. אף פעם."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, el teu banc — ningú no necessita la teva frase de recuperació. Mai."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, vaša banka — nikome ne treba vaša fraza za oporavak. Nikada."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, vaša banka — nikto vašu obnovovaciu frázu nepotrebuje. Nikdy."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, vaša banka — nihče ne potrebuje vaše obnovitvene fraze. Nikoli."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, ваша банка — никоме није потребна ваша фраза за опоравак. Никада."
          }
