        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "火と水に耐えるよう、金属に刻印してください。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prägen Sie sie in Metall, damit sie Feuer und Wasser übersteht."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gravez-la dans du métal pour résister au feu et à l’eau."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "불과 물에 견디도록 금속에 각인하세요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La incida nel metallo per resistere al fuoco e all’acqua."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yangına ve suya dayanması için metale işleyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khắc vào kim loại để chịu được lửa và nước."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ตอกลงบนโลหะเพื่อให้ทนไฟและทนน้ำ"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cetak ke logam agar tahan api dan air."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای مقاومت در برابر آتش و آب، آن را روی فلز حک کنید."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybij ją na metalu, aby przetrwała ogień i wodę."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sla hem in metaal voor brand- en waterbestendigheid."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Викарбуйте її на металі, щоб пережити вогонь і воду."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χαράξτε τη σε μέταλλο για επιβίωση σε φωτιά και νερό."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Marchează-o pe metal pentru a supraviețui focului și apei."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyražte ji do kovu, aby přežila oheň i vodu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Üsse fémbe, hogy túléljen tüzet és vizet."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Stansa in den i metall för att överleva eld och vatten."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Stans den inn i metall så den tåler ild og vann."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Præg den i metal, så den overlever ild og vand."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyö se metalliin, jotta se kestää tulen ja veden."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הטבע אותו במתכת כדי לשרוד אש ומים."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Estampa-la en metall perquè sobrevisqui al foc i a l’aigua."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utisnite je u metal kako bi preživjela vatru i vodu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyrazte ju do kovu, aby prežila oheň a vodu."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vtisnite jo v kovino, da preživi ogenj in vodo."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Утисните је у метал да преживи ватру и воду."
          }
        }
      }
