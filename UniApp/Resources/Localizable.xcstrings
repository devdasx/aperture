    "Generated on-device. Stored on-device. Aperture has no copy.": {
      "extractionState": "manual",
      "comment": "Slide 3 body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Generated on-device. Stored on-device. Aperture has no copy."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Generadas en el dispositivo. Guardadas en el dispositivo. Aperture no tiene copia."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设备上生成。在设备上保存。Aperture 没有副本。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在裝置上產生。在裝置上保存。Aperture 沒有副本。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिवाइस पर ही बनाया गया। डिवाइस पर ही रखा गया। Aperture के पास कोई प्रति नहीं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُولَّد على الجهاز. يُخزَّن على الجهاز. ولا توجد لدى Aperture أي نسخة."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Geradas no dispositivo. Guardadas no dispositivo. A Aperture não tem cópia."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ডিভাইসেই তৈরি। ডিভাইসেই সংরক্ষিত। Aperture-এর কাছে কোনো কপি নেই।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создаётся на устройстве. Хранится на устройстве. У Aperture нет копии."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス上で生成され、デバイス上に保存されます。Aperture は控えを持ちません。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf dem Gerät erzeugt. Auf dem Gerät gespeichert. Aperture besitzt keine Kopie."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Générées sur l’appareil. Conservées sur l’appareil. Aperture n’en a aucune copie."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기에서 생성하고, 기기에 보관합니다. Aperture는 사본을 갖지 않습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Generate sul dispositivo. Conservate sul dispositivo. Aperture non ne ha alcuna copia."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cihazda oluşturulur. Cihazda saklanır. Aperture'ın bir kopyası yoktur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Được tạo trên thiết bị. Lưu trên thiết bị. Aperture không giữ bản sao nào."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สร้างบนอุปกรณ์ จัดเก็บบนอุปกรณ์ Aperture ไม่มีสำเนาใดเลย"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dibuat di perangkat. Disimpan di perangkat. Aperture tidak menyimpan salinan apa pun."
