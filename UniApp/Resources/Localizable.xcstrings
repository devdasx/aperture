    "On paper. Not a screenshot. Not a note app.": {
      "extractionState": "manual",
      "comment": "Create-wallet disclosure protection rule 1 detail.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On paper. Not a screenshot. Not a note app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En papel. No en una captura. No en una app de notas."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "写在纸上。不是截图。不是备忘录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "寫在紙上。不是截圖。不是備忘錄。"
