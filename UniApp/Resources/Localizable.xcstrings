        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Rozumiem, že ak stratím obnovovaciu frázu, stratím svoje kryptomeny."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Razumem, da če izgubim obnovitveno frazo, izgubim svoje kriptovalute."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Разумем: ако изгубим фразу за опоравак, губим своју криптовалуту."
          }
        }
      }
    },
    "If you lose it, the funds are gone.": {
