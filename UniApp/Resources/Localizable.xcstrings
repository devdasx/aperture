    "Bitcoin, Ethereum, Solana, and twenty-one more — held together in a single place.": {
      "extractionState": "manual",
      "comment": "Slide 2 body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana, and twenty-one more — held together in a single place."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana y veintiuna redes más, en un solo lugar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin、Ethereum、Solana 以及另外二十一条网络——汇于一处。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin、Ethereum、Solana 以及另外二十一條網路——匯於一處。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana और इक्कीस अन्य — सब एक ही जगह।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin وEthereum وSolana وواحدٌ وعشرون غيرها — جميعها في مكان واحد."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana e mais vinte e uma — reunidas em um único lugar."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana এবং আরও একুশটি — সব এক জায়গায়।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana и ещё двадцать одна сеть — собраны в одном месте."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin、Ethereum、Solana、さらに 21 のネットワーク——すべてをひとつの場所に。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana und einundzwanzig weitere — an einem einzigen Ort vereint."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana, et vingt et un autres — réunis en un seul endroit."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana, 그리고 스물한 개의 네트워크가 한곳에 모입니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana e altri ventuno — riuniti in un solo posto."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana ve yirmi bir ağ daha — hepsi tek bir yerde."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana và hai mươi mốt mạng khác — gói gọn trong một nơi duy nhất."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin Ethereum Solana และอีกยี่สิบเอ็ดเครือข่าย รวมไว้ในที่เดียว"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana, dan dua puluh satu lainnya — tersatukan di satu tempat."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin، Ethereum، Solana و بیست و یک شبکه دیگر — همگی در یک مکان."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana i dwadzieścia jeden innych — w jednym miejscu."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana en eenentwintig andere — samen op één plek."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana і ще двадцять одна мережа — разом, в одному місці."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana και άλλα είκοσι ένα — μαζί, σε ένα σημείο."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana și încă douăzeci și unu — ținute laolaltă, într-un singur loc."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana a dalších dvacet jedna — pohromadě na jednom místě."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana és további huszonegy — egy helyen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana och tjugoen till — samlade på ett ställe."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana og tjueén andre — samlet på ett sted."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana og enogtyve mere — samlet på ét sted."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana ja kaksikymmentäyksi muuta — yhdessä paikassa."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana ועוד עשרים ואחת — יחד במקום אחד."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana i vint-i-una més — totes en un sol lloc."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana i još dvadeset jedna — sve na jednom mjestu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana a ďalších dvadsaťjeden — pohromade na jednom mieste."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana in še enaindvajset — vse na enem mestu."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitcoin, Ethereum, Solana и још двадесет једна — све на једном месту."
          }
        }
      }
    },
