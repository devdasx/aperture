    "Pick the word at each position to confirm you saved your phrase.": {
      "extractionState": "manual",
      "comment": "Backup-verify view subtitle copy.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick the word at each position to confirm you saved your phrase."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige la palabra de cada posición para confirmar que guardaste tu frase."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在每个位置选出正确的单词,确认你已经保存了短语。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在每個位置選出正確的字詞,以確認你已儲存短語。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपनी फ़्रेज़ सहेज लेने की पुष्टि के लिए हर स्थान पर सही शब्द चुनें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر الكلمة الصحيحة في كل موضع للتأكيد على أنك حفظت عبارتك."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a palavra de cada posição para confirmar que você guardou sua frase."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনি আপনার ফ্রেজ সংরক্ষণ করেছেন তা নিশ্চিত করতে প্রতিটি অবস্থানের শব্দটি বেছে নিন।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите слово для каждой позиции, чтобы подтвердить, что вы сохранили фразу."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各位置の単語を選び、フレーズを保存したことを確認してください。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie das Wort für jede Position, um zu bestätigen, dass Sie Ihre Phrase gesichert haben."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez le mot à chaque position pour confirmer que vous avez enregistré votre phrase."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 위치의 단어를 선택해 문구를 저장했는지 확인하세요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Selezioni la parola in ogni posizione per confermare di aver salvato la sua frase."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İfadenizi kaydettiğinizi doğrulamak için her konumdaki kelimeyi seçin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn từ ở mỗi vị trí để xác nhận bạn đã lưu cụm từ."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกคำในแต่ละตำแหน่งเพื่อยืนยันว่าคุณบันทึกวลีไว้แล้ว"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih kata pada setiap posisi untuk memastikan Anda telah menyimpan frasa."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "برای تأیید این‌که عبارت خود را ذخیره کرده‌اید، کلمهٔ هر جایگاه را انتخاب کنید."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz słowo na każdej pozycji, aby potwierdzić zapisanie frazy."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies het woord op elke positie om te bevestigen dat je je zin hebt opgeslagen."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть слово на кожній позиції, щоб підтвердити, що ви зберегли фразу."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε τη λέξη σε κάθε θέση για να επιβεβαιώσετε ότι αποθηκεύσατε τη φράση σας."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alege cuvântul de la fiecare poziție pentru a confirma că ai salvat expresia."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte slovo na každé pozici a potvrďte, že jste si frázi uložili."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassza ki az egyes pozíciókhoz tartozó szót, hogy igazolja: elmentette a kifejezést."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj ordet på varje position för att bekräfta att du har sparat din fras."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg ordet på hver posisjon for å bekrefte at du har lagret frasen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg ordet på hver position for at bekræfte, at du har gemt din sætning."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse sana kullakin paikalla vahvistaaksesi, että tallensit lauseen."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר את המילה בכל מיקום כדי לאשר ששמרת את הביטוי."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tria la paraula a cada posició per confirmar que has desat la frase."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite riječ na svakoj poziciji kako biste potvrdili da ste spremili frazu."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte slovo na každej pozícii a potvrďte, že ste si frázu uložili."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Izberite besedo na vsakem mestu in potrdite, da ste frazo shranili."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Изаберите реч на свакој позицији да потврдите да сте сачували фразу."
          }
        }
      }
    },
