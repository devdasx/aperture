        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我明白：遺失助記詞，就等於失去我的加密資產。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मुझे समझ है: अगर मेरा रिकवरी फ़्रेज़ खो गया, तो मेरी क्रिप्टो भी खो जाती है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أُدرك أنّني إذا فقدت عبارة الاسترداد، فقدتُ عملاتي المُشفَّرة."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Eu entendo que se eu perder minha frase de recuperação, eu perco minhas criptos."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আমি বুঝি, রিকভারি ফ্রেজ হারালে আমার ক্রিপ্টোও হারিয়ে যায়।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Я понимаю: если я потеряю фразу восстановления, я потеряю свою криптовалюту."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リカバリーフレーズを失えば、私の暗号資産も失われることを理解しています。"
