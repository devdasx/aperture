    "Balances are read from public chains on your device. Nothing flows to us.": {
      "extractionState": "manual",
      "comment": "Slide 9 body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Balances are read from public chains on your device. Nothing flows to us."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los saldos se leen desde las cadenas públicas en tu dispositivo. Nada llega a nosotros."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "余额由你的设备直接从公链读取。没有任何数据流向我们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "餘額由你的裝置直接從公鏈讀取。沒有任何資料流向我們。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बैलेंस आपके डिवाइस पर सार्वजनिक चेन से पढ़े जाते हैं। हमें कुछ भी नहीं भेजा जाता।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُقرأ الأرصدة من السلاسل العامة على جهازك. لا شيء يصل إلينا."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os saldos são lidos das redes públicas no seu dispositivo. Nada chega até nós."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ব্যালেন্স আপনার ডিভাইসেই পাবলিক চেইন থেকে পড়া হয়। কিছুই আমাদের কাছে আসে না।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Балансы считываются с публичных сетей прямо на вашем устройстве. К нам ничего не поступает."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "残高はあなたのデバイス上で、公開チェーンから直接読み取られます。私たちには何も流れてきません。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Guthaben werden auf Ihrem Gerät direkt aus den öffentlichen Chains gelesen. Zu uns fließt nichts."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les soldes sont lus sur les réseaux publics depuis votre appareil. Rien ne nous parvient."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잔액은 사용자 기기에서 퍼블릭 체인을 읽어 표시합니다. 저희 쪽으로 흘러오는 정보는 없습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I saldi vengono letti dalle reti pubbliche sul suo dispositivo. Nulla arriva fino a noi."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bakiyeler, cihazınızda kamuya açık ağlardan okunur. Bize hiçbir şey akmaz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Số dư được đọc từ các mạng công khai trên thiết bị của bạn. Không có gì truyền về chúng tôi."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยอดคงเหลือถูกอ่านจากเครือข่ายสาธารณะบนอุปกรณ์ของคุณ ไม่มีข้อมูลใดส่งมาที่เรา"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Saldo dibaca dari jaringan publik di perangkat Anda. Tidak ada yang mengalir ke kami."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "موجودی‌ها از شبکه‌های عمومی روی دستگاه شما خوانده می‌شوند. هیچ چیز به سمت ما نمی‌آید."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Salda są odczytywane z publicznych sieci na Twoim urządzeniu. Nic do nas nie trafia."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Saldi worden op je apparaat uit openbare netwerken gelezen. Niets stroomt naar ons."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Баланси зчитуються з публічних мереж на вашому пристрої. До нас нічого не передається."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα υπόλοιπα διαβάζονται από δημόσιες αλυσίδες στη συσκευή σας. Τίποτα δεν φτάνει σε εμάς."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Soldurile sunt citite din lanțurile publice de pe dispozitivul tău. Nimic nu ajunge la noi."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zůstatky se čtou z veřejných řetězců přímo na vašem zařízení. K nám nic neteče."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az egyenlegeket nyilvános láncokból olvassuk be az Ön készülékén. Semmi nem jut el hozzánk."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Saldon läses från publika kedjor på din enhet. Inget når oss."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Saldoer leses fra offentlige kjeder på enheten din. Ingenting går til oss."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Saldi læses fra offentlige kæder på din enhed. Intet sendes til os."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Saldot luetaan julkisista ketjuista laitteellasi. Meille ei mene mitään."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "היתרות נקראות מרשתות ציבוריות במכשיר שלך. שום דבר לא זורם אלינו."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Els saldos es llegeixen de cadenes públiques al teu dispositiu. No ens arriba res."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saldi se čitaju s javnih lanaca na vašem uređaju. Ništa ne dolazi do nas."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Zostatky sa čítajú z verejných reťazcov na vašom zariadení. K nám neprúdi nič."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stanja se berejo iz javnih verig na vaši napravi. Do nas ne pride nič."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Стања се читају са јавних мрежа на вашем уређају. До нас не долази ништа."
          }
        }
      }
    },
