            "value": "Сохраните фразу восстановления, прежде чем пропустить шаг."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スキップする前に、リカバリーフレーズを保存してください。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sichern Sie Ihre Wiederherstellungsphrase, bevor Sie überspringen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez votre phrase de récupération avant de passer."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "건너뛰기 전에 복구 문구를 저장하세요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvi la sua frase di ripristino prima di saltare questo passaggio."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Atlamadan önce kurtarma ifadenizi kaydedin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hãy lưu cụm từ khôi phục trước khi bỏ qua."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกวลีกู้คืนก่อนข้ามขั้นตอนนี้"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Simpan frasa pemulihan Anda sebelum melewati langkah ini."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "پیش از رد کردن، عبارت بازیابی خود را ذخیره کنید."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisz frazę odzyskiwania, zanim ją pominiesz."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sla je herstelzin op voordat je deze stap overslaat."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Збережіть фразу відновлення, перш ніж пропустити цей крок."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αποθηκεύστε τη φράση ανάκτησης πριν παρακάμψετε."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvează expresia de recuperare înainte să omiți pasul."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uložte si obnovovací frázi, než tento krok přeskočíte."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mentse el a helyreállítási kifejezést, mielőtt kihagyja."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Spara din återställningsfras innan du hoppar över."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lagre gjenopprettingsfrasen før du hopper over."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gem din gendannelsessætning, før du springer over."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tallenna palautuslause ennen kuin ohitat."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שמור את ביטוי השחזור לפני שתדלג."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Desa la teva frase de recuperació abans d’ometre el pas."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Spremite frazu za oporavak prije nego što preskočite korak."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Uložte si obnovovaciu frázu skôr, než tento krok preskočíte."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Shranite obnovitveno frazo, preden korak preskočite."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Сачувајте фразу за опоравак пре него што прескочите корак."
          }
        }
      }
    },
    "Saving your recovery phrase as a screenshot is risky. Screenshots sync to iCloud, appear in your photo library and Recents, and can be read by anyone with your unlocked phone.": {
      "comment": "Body copy in the screenshot-warning sheet explaining the real risks of screenshotting a recovery phrase.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Saving your recovery phrase as a screenshot is risky. Screenshots sync to iCloud, appear in your photo library and Recents, and can be read by anyone with your unlocked phone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guardar tu frase de recuperación como captura de pantalla es arriesgado. Las capturas se sincronizan con iCloud, aparecen en tu fototeca y en Recientes, y cualquiera puede leerlas si tu teléfono está desbloqueado."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将恢复短语保存为截屏存在风险。截屏会同步到 iCloud,出现在照片图库和「最近项目」中,任何人在你的手机解锁时都能看到。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將恢復短語儲存為截圖有風險。截圖會同步至 iCloud、出現在照片圖庫和「最近項目」中,任何人在你的手機解鎖時都能讀取。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने रिकवरी फ़्रेज़ को स्क्रीनशॉट के रूप में सहेजना जोखिम भरा है। स्क्रीनशॉट iCloud से सिंक होते हैं, आपकी फ़ोटो लाइब्रेरी और हाल ही में में दिखते हैं, और जिसके पास आपका अनलॉक फ़ोन हो वह इन्हें पढ़ सकता है।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حفظ عبارة الاسترداد كلقطة شاشة محفوف بالمخاطر. تتزامن لقطات الشاشة مع iCloud، وتظهر في مكتبة الصور وفي «الأخيرة»، ويمكن لأي شخص يحمل هاتفك وهو مفتوح القفل أن يقرأها."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvar sua frase de recuperação como captura de tela é arriscado. Capturas de tela sincronizam com o iCloud, aparecem na sua fototeca e em Recentes, e podem ser lidas por qualquer pessoa com seu telefone desbloqueado."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার রিকভারি ফ্রেজ স্ক্রিনশট হিসেবে সংরক্ষণ করা ঝুঁকিপূর্ণ। স্ক্রিনশট iCloud-এ সিঙ্ক হয়, আপনার ফটো লাইব্রেরি ও Recents-এ দেখা যায়, এবং আপনার আনলক করা ফোন যার হাতে থাকবে সে এগুলো পড়তে পারবে।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохранять фразу восстановления как снимок экрана опасно. Снимки экрана синхронизируются с iCloud, появляются в медиатеке и в разделе «Недавние», и их может прочитать любой, у кого окажется ваш разблокированный телефон."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リカバリーフレーズをスクリーンショットとして保存するのは危険です。スクリーンショットは iCloud と同期され、写真ライブラリと「最近の項目」に表示され、ロック解除された端末を手にした人なら誰でも読めてしまいます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Wiederherstellungsphrase als Bildschirmfoto zu sichern ist riskant. Bildschirmfotos werden mit iCloud synchronisiert, erscheinen in Ihrer Fotomediathek und in „Zuletzt“, und jeder mit Zugriff auf Ihr entsperrtes Telefon kann sie lesen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrer votre phrase de récupération sous forme de capture d'écran est risqué. Les captures se synchronisent avec iCloud, apparaissent dans votre photothèque et dans Récents, et peuvent être lues par quiconque tient votre iPhone déverrouillé."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "복구 문구를 스크린샷으로 저장하는 것은 위험합니다. 스크린샷은 iCloud로 동기화되고, 사진 보관함과 최근 항목에 표시되며, 잠금이 해제된 iPhone을 가진 누구든 읽을 수 있습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvare la frase di ripristino come screenshot è rischioso. Gli screenshot si sincronizzano con iCloud, compaiono nella libreria foto e in Recenti e possono essere letti da chiunque abbia il Suo iPhone sbloccato."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kurtarma ifadenizi ekran görüntüsü olarak kaydetmek risklidir. Ekran görüntüleri iCloud'a eşitlenir, fotoğraf kitaplığınızda ve Son Kullanılanlar'da görünür ve kilidi açık telefonunuzu eline geçiren herkes tarafından okunabilir."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lưu cụm từ khôi phục dưới dạng ảnh chụp màn hình là rất rủi ro. Ảnh chụp đồng bộ với iCloud, xuất hiện trong thư viện ảnh và mục Gần đây, và bất kỳ ai cầm iPhone đã mở khoá của bạn đều có thể đọc được."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การบันทึกวลีกู้คืนเป็นภาพหน้าจอเป็นความเสี่ยง ภาพหน้าจอจะซิงค์กับ iCloud ปรากฏในคลังภาพและล่าสุด และใครก็ตามที่ถือ iPhone ของคุณในสถานะปลดล็อกอยู่สามารถอ่านได้"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menyimpan frasa pemulihan sebagai tangkapan layar berisiko. Tangkapan layar tersinkron ke iCloud, muncul di pustaka foto dan Terbaru, dan dapat dibaca siapa pun yang memegang iPhone Anda dalam keadaan terbuka."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "ذخیره عبارت بازیابی به‌صورت اسکرین‌شات پرخطر است. اسکرین‌شات‌ها با iCloud هم‌گام می‌شوند، در کتابخانه عکس‌ها و بخش اخیر دیده می‌شوند، و هر کسی که iPhone قفل‌گشوده شما را در دست داشته باشد می‌تواند آن‌ها را بخواند."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisywanie frazy odzyskiwania w postaci zrzutu ekranu jest ryzykowne. Zrzuty ekranu synchronizują się z iCloud, pojawiają się w bibliotece zdjęć i w albumie Ostatnie oraz może je odczytać każdy, kto ma odblokowany iPhone."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je herstelzin opslaan als schermafbeelding is riskant. Schermafbeeldingen worden gesynchroniseerd met iCloud, verschijnen in je fotobibliotheek en in Recent, en kunnen worden gelezen door iedereen met je ontgrendelde iPhone."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зберігати фразу відновлення як скріншот ризиковано. Скріншоти синхронізуються з iCloud, потрапляють у фотобібліотеку та «Останні», і їх може прочитати будь-хто з вашим розблокованим телефоном."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η αποθήκευση της φράσης ανάκτησης ως στιγμιότυπο οθόνης είναι επικίνδυνη. Τα στιγμιότυπα συγχρονίζονται με το iCloud, εμφανίζονται στη βιβλιοθήκη φωτογραφιών και στα Πρόσφατα, και μπορούν να διαβαστούν από οποιονδήποτε με ξεκλείδωτο το τηλέφωνό σας."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Salvarea expresiei de recuperare ca o captură de ecran este riscantă. Capturile se sincronizează cu iCloud, apar în biblioteca foto și în Recente și pot fi citite de oricine cu telefonul tău deblocat."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Ukládat obnovovací frázi jako snímek obrazovky je rizikové. Snímky se synchronizují s iCloudem, objevují se ve fotoknihovně i v Naposledy a může je číst kdokoli s odemčeným telefonem."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kockázatos a helyreállítási kifejezést képernyőfotóként menteni. A képernyőfotók szinkronizálódnak az iCloudba, megjelennek a fotókönyvtárban és a Legutóbbiakban, és bárki elolvashatja, akinek feloldva a kezében van a telefonja."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Att spara din återställningsfras som en skärmavbild är riskabelt. Skärmavbilder synkar till iCloud, dyker upp i ditt fotobibliotek och i Senaste, och kan läsas av vem som helst med din olåsta telefon."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er risikabelt å lagre gjenopprettingsfrasen som skjermdump. Skjermdumper synkroniseres til iCloud, vises i bildebiblioteket og i Nylig, og kan leses av enhver som har telefonen din ulåst."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er risikabelt at gemme din gendannelsessætning som et skærmbillede. Skærmbilleder synkroniseres til iCloud, vises i dit fotobibliotek og under Seneste, og kan læses af enhver med din ulåste telefon."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Palautuslauseen tallentaminen kuvakaappauksena on riskialtista. Kuvakaappaukset synkronoituvat iCloudiin, näkyvät kuvakirjastossa ja Viimeisimmissä, ja kuka tahansa lukitsemattomalla puhelimellasi voi lukea ne."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שמירת ביטוי השחזור כצילום מסך מסוכנת. צילומי מסך מסונכרנים ל-iCloud, מופיעים בספריית התמונות וב\"אחרונים\", וכל מי שמחזיק בטלפון שלך לא נעול יכול לקרוא אותם."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Desar la teva frase de recuperació com una captura és arriscat. Les captures se sincronitzen amb iCloud, apareixen a la fototeca i a Recents, i les pot llegir qualsevol amb el teu telèfon desbloquejat."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Spremanje fraze za oporavak kao snimke zaslona riskantno je. Snimke zaslona sinkroniziraju se s iCloudom, pojavljuju se u foto biblioteci i u Nedavnim, i može ih pročitati svatko tko ima vaš otključani telefon."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Uložiť obnovovaciu frázu ako snímku obrazovky je riskantné. Snímky sa synchronizujú s iCloudom, objavujú sa vo fotoknižnici a v Naposledy a môže ich prečítať ktokoľvek s odomknutým telefónom."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Shranjevanje obnovitvene fraze kot posnetka zaslona je tvegano. Posnetki zaslona se sinhronizirajo z iCloudom, pojavijo se v knjižnici fotografij in v razdelku Nedavno, in lahko jih prebere vsak, ki ima vaš odklenjen telefon."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Чување фразе за опоравак као снимка екрана је ризично. Снимци екрана се синхронизују са iCloud-ом, појављују се у фото-библиотеци и у „Недавно“, и може их прочитати свако ко има ваш откључани телефон."
          }
        }
      }
    },
