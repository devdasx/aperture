        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আগুন ও পানিতে টিকে থাকার জন্য এটি ধাতুতে খোদাই করুন।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбейте её на металле, чтобы она пережила огонь и воду."
