          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, vaše banka — nikdo vaši obnovovací frázi nepotřebuje. Nikdy."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az Aperture, az Apple, az Ön bankja — senkinek nincs szüksége a helyreállítási kifejezésére. Soha."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, din bank — ingen behöver din återställningsfras. Aldrig."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, banken din — ingen trenger gjenopprettingsfrasen din. Aldri."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, din bank — ingen har brug for din gendannelsessætning. Aldrig."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, pankkisi — kukaan ei tarvitse palautuslausettasi. Ei koskaan."
