    "Every signature is gated by your biometrics. No password to forget.": {
      "extractionState": "manual",
      "comment": "Slide 4 body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every signature is gated by your biometrics. No password to forget."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada firma queda protegida por tu biometría. Sin contraseñas que olvidar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每一次签名都由你的生物识别把关。再无密码可忘。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每一次簽名都由你的生物辨識把關。再無密碼可忘。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हर हस्ताक्षर आपकी बायोमेट्रिक्स से सुरक्षित है। भूलने के लिए कोई पासवर्ड नहीं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل توقيع محميٌّ بقياساتك الحيوية. لا كلمة سرٍّ تُنسى."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toda assinatura passa pela sua biometria. Nenhuma senha para esquecer."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিটি সই আপনার বায়োমেট্রিক্স দ্বারা সুরক্ষিত। ভুলে যাওয়ার মতো কোনো পাসওয়ার্ড নেই।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждая подпись подтверждается вашей биометрией. Никаких паролей, которые можно забыть."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての署名は、あなたの生体認証によって守られます。忘れるべきパスワードはありません。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jede Signatur wird durch Ihre Biometrie freigegeben. Kein Passwort, das man vergessen könnte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque signature passe par votre biométrie. Aucun mot de passe à retenir."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 서명은 생체 인증을 거칩니다. 잊을 비밀번호가 없습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni firma passa dalla sua biometria. Nessuna password da ricordare."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her imza biyometriden geçer. Unutulacak parola yok."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mỗi chữ ký đều cần xác thực sinh trắc học. Không có mật khẩu để quên."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ทุกการลงนามผ่านการยืนยันด้วยข้อมูลชีวมิติ ไม่มีรหัสผ่านให้ต้องจำ"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Setiap tanda tangan melewati biometrik Anda. Tidak ada kata sandi untuk dilupakan."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "هر امضا با شناسایی زیستی شما تأیید می‌شود. هیچ گذرواژه‌ای برای فراموش کردن نیست."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każdy podpis wymaga biometrii. Brak hasła do zapamiętania."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elke ondertekening verloopt via je biometrie. Geen wachtwoord om te onthouden."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кожен підпис захищений вашою біометрією. Жодного пароля, який можна забути."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κάθε υπογραφή προστατεύεται από τα βιομετρικά σας. Καμία κωδική φράση προς απομνημόνευση."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fiecare semnătură e blocată de biometria ta. Nicio parolă de uitat."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Každý podpis je střežen vaší biometrií. Žádné heslo k zapomenutí."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Minden aláírást a biometria véd. Nincs jelszó, amit elfelejthetne."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Varje signatur kräver din biometri. Inget lösenord att glömma."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hver signatur sikres av biometrien din. Ingen passord å glemme."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hver signatur er låst bag din biometri. Intet kodeord at glemme."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jokainen allekirjoitus vaatii biometriikkasi. Ei salasanaa, jonka voisi unohtaa."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כל חתימה דורשת ביומטריה שלך. אין סיסמה לשכוח."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada signatura passa per la teva biometria. Cap contrasenya per oblidar."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Svaki je potpis zaštićen vašom biometrijom. Nema lozinke za zaboraviti."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Každý podpis je chránený vašou biometriou. Žiadne heslo na zabudnutie."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vsak podpis je zaščiten z vašo biometrijo. Nobenega gesla, ki bi ga bilo mogoče pozabiti."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Сваки потпис чува ваша биометрија. Нема лозинке коју бисте могли заборавити."
          }
        }
      }
    },
