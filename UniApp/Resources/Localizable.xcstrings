    "Aperture, Apple, your bank — no one needs your recovery phrase. Ever.": {
      "extractionState": "manual",
      "comment": "Create-wallet disclosure protection rule 3 detail.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, your bank — no one needs your recovery phrase. Ever."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, tu banco: nadie necesita tu frase de recuperación. Nunca."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture、Apple、你的银行——没有人需要你的助记词。永远不会。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture、Apple、你的銀行——沒有人需要你的助記詞。永遠不會。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, आपका बैंक — किसी को भी आपके रिकवरी फ़्रेज़ की ज़रूरत नहीं है। कभी नहीं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture وApple ومصرفك — لا أحد بحاجة إلى عبارة الاسترداد الخاصة بك. أبدًا."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, seu banco — ninguém precisa da sua frase de recuperação. Nunca."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, আপনার ব্যাংক — কারও আপনার রিকভারি ফ্রেজের প্রয়োজন নেই। কখনও না।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, ваш банк — никому не нужна ваша фраза восстановления. Никогда."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture も Apple もあなたの銀行も、誰一人としてあなたのリカバリーフレーズを必要としません。一度たりとも。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, Ihre Bank — niemand braucht Ihre Wiederherstellungsphrase. Niemals."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, votre banque — personne n’a besoin de votre phrase de récupération. Jamais."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture도, Apple도, 은행도 — 누구도 복구 문구를 필요로 하지 않습니다. 절대로."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, la sua banca — nessuno ha bisogno della sua frase di ripristino. Mai."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, bankanız — hiç kimsenin kurtarma ifadenize ihtiyacı yoktur. Asla."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, ngân hàng của bạn — không ai cần cụm từ khôi phục của bạn. Không bao giờ."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, ธนาคารของคุณ — ไม่มีใครต้องการวลีกู้คืนของคุณ ไม่ว่าเมื่อใด"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, bank Anda — tidak ada yang membutuhkan frasa pemulihan Anda. Tidak pernah."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture، Apple، بانک شما — هیچ‌کس به عبارت بازیابی شما نیاز ندارد. هرگز."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, twój bank — nikt nie potrzebuje twojej frazy odzyskiwania. Nigdy."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, je bank — niemand heeft je herstelzin nodig. Nooit."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, ваш банк — нікому не потрібна ваша фраза відновлення. Ніколи."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Aperture, Apple, η τράπεζά σας — κανείς δεν χρειάζεται τη φράση ανάκτησής σας. Ποτέ."
