        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mir ist klar: Wenn ich meine Wiederherstellungsphrase verliere, verliere ich meine Krypto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je comprends que si je perds ma phrase de récupération, je perds mes cryptos."
