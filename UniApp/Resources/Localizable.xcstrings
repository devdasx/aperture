    "The network fee is displayed before you sign. No surprises after.": {
      "extractionState": "manual",
      "comment": "Slide 7 body.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The network fee is displayed before you sign. No surprises after."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La comisión de red se muestra antes de firmar. Sin sorpresas después."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络手续费会在你签名前显示。事后绝无意外。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "網路手續費會在你簽名前顯示。事後絕無意外。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "नेटवर्क शुल्क हस्ताक्षर से पहले दिखाया जाता है। बाद में कोई आश्चर्य नहीं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُعرض رسوم الشبكة قبل التوقيع. لا مفاجآت بعد ذلك."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A taxa de rede é exibida antes de você assinar. Nenhuma surpresa depois."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সই করার আগেই নেটওয়ার্ক ফি দেখানো হয়। পরে কোনো চমক নেই।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Комиссия сети показывается до подписи. Никаких сюрпризов после."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク手数料は署名の前に表示されます。あとからの驚きはありません。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Netzwerkgebühr wird vor der Signatur angezeigt. Keine Überraschungen danach."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les frais de réseau s’affichent avant la signature. Aucune surprise ensuite."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "네트워크 수수료는 서명 전에 표시됩니다. 뒤늦은 놀라움은 없습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La commissione di rete è mostrata prima della firma. Nessuna sorpresa dopo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ağ ücreti, imzadan önce gösterilir. Sonradan sürpriz olmaz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phí mạng được hiển thị trước khi bạn ký. Không có bất ngờ về sau."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ค่าธรรมเนียมเครือข่ายแสดงก่อนการลงนาม ไม่มีเซอร์ไพรส์ภายหลัง"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Biaya jaringan ditampilkan sebelum Anda menandatangani. Tidak ada kejutan setelahnya."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "کارمزد شبکه پیش از امضا نمایش داده می‌شود. هیچ غافلگیری پس از آن نخواهد بود."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opłata sieciowa jest pokazywana przed podpisaniem. Później bez niespodzianek."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De netwerkkosten zijn zichtbaar voordat je ondertekent. Geen verrassingen achteraf."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Комісію мережі видно ще до підпису. Жодних сюрпризів після."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η προμήθεια δικτύου εμφανίζεται πριν υπογράψετε. Καμία έκπληξη μετά."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Comisionul rețelei e afișat înainte să semnezi. Fără surprize după."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Poplatek sítě se zobrazí ještě před podpisem. Žádná překvapení po něm."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hálózati díj a aláírás előtt látszik. Utána nincs meglepetés."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Nätverksavgiften visas innan du signerar. Inga överraskningar efteråt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Nettverksgebyret vises før du signerer. Ingen overraskelser etterpå."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Netværksgebyret vises, før du underskriver. Ingen overraskelser bagefter."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Verkkomaksu näkyy ennen allekirjoittamista. Ei yllätyksiä jälkikäteen."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "עמלת הרשת מוצגת לפני החתימה. בלי הפתעות אחרי."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La comissió de xarxa es mostra abans de signar. Cap sorpresa després."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Naknada mreže prikazuje se prije potpisivanja. Bez iznenađenja poslije."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Sieťový poplatok sa zobrazí pred podpisom. Žiadne prekvapenia potom."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Omrežna provizija je prikazana pred podpisom. Brez presenečenj pozneje."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Накнада мреже приказује се пре потписивања. Без изненађења после."
          }
        }
      }
    },
    "There is no support team, no password reset, no recovery.": {
      "extractionState": "manual",
      "comment": "Create-wallet disclosure protection rule 4 detail.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There is no support team, no password reset, no recovery."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay equipo de soporte, no hay restablecimiento de contraseña, no hay recuperación."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有客服团队，没有密码重置，没有找回机制。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "沒有客服團隊，沒有密碼重設，沒有找回機制。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई सपोर्ट टीम नहीं, कोई पासवर्ड रीसेट नहीं, कोई रिकवरी नहीं।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا فريق دعم، ولا إعادة تعيين لكلمة السر، ولا استرداد."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não existe equipe de suporte, nem redefinição de senha, nem recuperação."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কোনো সাপোর্ট টিম নেই, কোনো পাসওয়ার্ড রিসেট নেই, কোনো রিকভারি নেই।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нет службы поддержки, нет сброса пароля, нет восстановления."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サポートチームはありません。パスワードのリセットもなく、復元の手段もありません。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es gibt kein Support-Team, kein Passwort-Reset, keine Wiederherstellung."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il n’y a pas d’équipe de support, pas de réinitialisation de mot de passe, aucune récupération."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지원팀도, 비밀번호 재설정도, 복구도 없습니다."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non c’è un team di supporto, non c’è il reset della password, non c’è il recupero."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Destek ekibi yoktur, parola sıfırlama yoktur, kurtarma yoktur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có đội ngũ hỗ trợ, không có đặt lại mật khẩu, không có khôi phục."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีทีมสนับสนุน ไม่มีการรีเซ็ตรหัสผ่าน ไม่มีการกู้คืน"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada tim dukungan, tidak ada penyetelan ulang kata sandi, tidak ada pemulihan."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "نه تیم پشتیبانی هست، نه بازنشانی رمز عبور، نه بازیابی."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie ma zespołu wsparcia, nie ma resetu hasła, nie ma odzyskania."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is geen supportteam, geen wachtwoordherstel, geen recovery."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тут немає служби підтримки, немає скидання пароля, немає відновлення."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν υπάρχει ομάδα υποστήριξης, ούτε επαναφορά κωδικού, ούτε ανάκτηση."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu există echipă de suport, nici resetare de parolă, nici recuperare."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Není zde tým podpory, není obnovení hesla, není obnova."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincs ügyfélszolgálat, nincs jelszóvisszaállítás, nincs helyreállítás."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det finns ingen supportkontakt, ingen lösenordsåterställning, ingen återställning."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det finnes ingen brukerstøtte, ingen passordtilbakestilling, ingen gjenoppretting."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der er ingen supportafdeling, ingen nulstilling af adgangskode, ingen gendannelse."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tukea ei ole, salasanaa ei voi nollata, palautusta ei ole."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אין צוות תמיכה, אין איפוס סיסמה, אין שחזור."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No hi ha equip de suport, no hi ha restabliment de contrasenya, no hi ha recuperació."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nema podrške, nema resetiranja lozinke, nema oporavka."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Neexistuje tím podpory, neexistuje obnovenie hesla, neexistuje obnova."
          }
        },
        "sl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ni ekipe za podporo, ni ponastavitve gesla, ni obnove."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Нема тима за подршку, нема ресетовања лозинке, нема опоравка."
          }
        }
      }
    },
    "These 12 words are your wallet. Write them in order, exactly as shown.": {
      "extractionState": "manual",
      "comment": "Recovery-phrase view hero copy.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These 12 words are your wallet. Write them in order, exactly as shown."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estas 12 palabras son tu billetera. Escríbelas en orden, exactamente como aparecen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这 12 个单词就是你的钱包。请按所示的顺序，原样抄写。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這 12 個單字就是你的錢包。請按所示的順序，原樣抄寫。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ये 12 शब्द ही आपकी वॉलेट हैं। जिस क्रम में दिखाए गए हैं, ठीक उसी क्रम में लिख लें।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذه الكلمات الاثنتا عشرة هي محفظتك. اكتبها بالترتيب، تمامًا كما تُعرض."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Estas 12 palavras são a sua carteira. Anote-as em ordem, exatamente como mostradas."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই ১২টি শব্দই আপনার ওয়ালেট। যে ক্রমে দেখানো হয়েছে, ঠিক সেই ক্রমেই লিখে রাখুন।"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эти 12 слов — ваш кошелёк. Запишите их по порядку, ровно так, как они показаны."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この 12 個の単語が、あなたのウォレットです。表示された順番のまま、正確に書き写してください。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese 12 Wörter sind Ihre Wallet. Schreiben Sie sie in der Reihenfolge auf, genau wie angezeigt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces 12 mots sont votre portefeuille. Notez-les dans l’ordre, exactement comme affichés."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 12개의 단어가 당신의 지갑입니다. 표시된 순서 그대로 정확히 적어 두세요."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Queste 12 parole sono il suo portafoglio. Le scriva nell’ordine, esattamente come mostrate."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu 12 kelime sizin cüzdanınızdır. Gösterildiği sırayla, tam olarak yazın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "12 từ này là ví của bạn. Hãy ghi theo đúng thứ tự, chính xác như hiển thị."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คำ 12 คำนี้คือกระเป๋าของคุณ จดตามลำดับ ตรงตามที่แสดงทุกประการ"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "12 kata ini adalah dompet Anda. Tulis berurutan, persis seperti yang ditampilkan."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
