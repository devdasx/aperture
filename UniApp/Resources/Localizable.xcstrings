    "Stamp it into metal for fire and water survival.": {
      "comment": "Third better-method row in the screenshot-warning sheet — stamp the phrase into metal for durability.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stamp it into metal for fire and water survival."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Grábala en metal para que sobreviva al fuego y al agua."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将它刻入金属,以抵御火与水。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將它刻入金屬,以抵禦火與水。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे धातु पर अंकित करें ताकि यह आग और पानी में बची रहे।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اطبعها على المعدن لتصمد أمام النار والماء."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Grave em metal para resistir a fogo e água."
