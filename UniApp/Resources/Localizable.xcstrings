    "Write it down.": {
      "extractionState": "manual",
      "comment": "Create-wallet disclosure protection rule 1 title.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Write it down."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Anótala."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "把它写下来。"
          }
        },
        "zh-Hant": {
