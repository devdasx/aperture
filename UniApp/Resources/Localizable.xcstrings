            "value": "Palautuslauseesi on ainoa tie takaisin."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ביטוי השחזור הוא הדרך היחידה חזרה."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La teva frase de recuperació és l’única manera de tornar."
          }
        },
        "hr": {
          "stringUnit": {
