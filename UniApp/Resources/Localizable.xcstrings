    "Copied. The clipboard clears in 60 seconds.": {
      "comment": "Transient footnote confirmation shown after the user taps Copy on the recovery-phrase view. Names the OS-managed clipboard expiry.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Copied. The clipboard clears in 60 seconds."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiado. El portapapeles se borra en 60 segundos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已复制。剪贴板将在 60 秒后清空。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已複製。剪貼簿將在 60 秒後清除。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कॉपी हो गया। क्लिपबोर्ड 60 सेकंड में साफ़ हो जाएगा।"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
